ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
PORT=5000
NODE_ENV=development

# PostgreSQL Database URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sinav_platformu"

# Ollama Ayarları (Yerel AI Modelleri)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=zephyr

# Gemini API (İsteğe bağlı - Cloud AI)
GEMINI_API_KEY=your_gemini_api_key_here

# Web Search (İsteğe bağlı - DuckDuckGo otomatik çalışır)
BRAVE_SEARCH_API_KEY=your_brave_api_key_here
ENABLE_WEB_SEARCH=true
